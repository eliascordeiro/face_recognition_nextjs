# Fornecido automaticamente pelo Railway ao adicionar o addon PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/railway

# Segredo para assinar tokens JWT — use uma string longa e aleatória
JWT_SECRET=mude-este-segredo-antes-de-usar-em-producao

# Admin padrão criado na primeira inicialização
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
